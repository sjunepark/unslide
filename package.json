{
  "name": "unslide",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.15 <25"
  },
  "bin": {
    "unslide": "bin/unslide.mjs"
  },
  "exports": {
    "./react": {
      "types": "./dist/unslide/react.d.ts",
      "default": "./dist/unslide/react.js"
    },
    "./schema/unslide.json": "./schema/unslide.schema.json",
    "./protocol.md": "./docs/PROTOCOL.md",
    "./support.md": "./docs/SUPPORT.md"
  },
  "files": [
    "bin/unslide.mjs",
    "dist/**/*.js",
    "dist/unslide/react.d.ts",
    "dist/unslide/render.d.ts",
    "docs/PROTOCOL.md",
    "docs/SUPPORT.md",
    "schema/unslide.schema.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:package": "node scripts/clean-package.mjs && tsc -p tsconfig.build.json",
    "prepack": "pnpm run build:package",
    "unslide": "pnpm --silent run build:package && ./bin/unslide.mjs",
    "check": "effect-language-service patch && tsc --noEmit",
    "test": "tsx --test tests/*.test.tsx",
    "validate": "pnpm run check && pnpm test && pnpm run render:spike && pnpm run capture:spike && pnpm run export:spike && pnpm run inspect-pdf:spike && pnpm run render:report && pnpm run capture:report && pnpm run export:report && pnpm run inspect-pdf:report",
    "render:report": "pnpm --silent run unslide build operating-review",
    "capture:report": "pnpm --silent run unslide capture operating-review",
    "export:report": "pnpm --silent run unslide export operating-review",
    "inspect-pdf:report": "pnpm --silent run unslide inspect-pdf operating-review",
    "render:spike": "pnpm --silent run unslide build spike",
    "capture:spike": "pnpm --silent run unslide capture spike",
    "export:spike": "pnpm --silent run unslide export spike",
    "inspect-pdf:spike": "pnpm --silent run unslide inspect-pdf spike"
  },
  "dependencies": {
    "@napi-rs/canvas": "1.0.2",
    "@toon-format/toon": "2.3.0",
    "@types/react": "19.1.8",
    "ajv": "8.20.0",
    "effect": "4.0.0-beta.97",
    "pdfjs-dist": "6.1.200",
    "playwright": "1.61.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tsx": "4.20.3"
  },
  "devDependencies": {
    "@effect/language-service": "0.87.0",
    "@types/node": "24.0.13",
    "@types/react-dom": "19.1.6",
    "typescript": "5.8.3"
  }
}
